{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "Bash(npm run *)",
      "Bash(npx vitest *)",
      "Bash(mkdir *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "TaskCreate|TaskUpdate|SendMessage|Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/activity-logger.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/activity-logger.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/activity-logger.sh"
          }
        ]
      }
    ]
  }
}
